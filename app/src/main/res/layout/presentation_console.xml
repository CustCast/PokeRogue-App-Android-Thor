<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Child 0: BUSY -->
        <FrameLayout
            android:id="@+id/layoutBusy"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="STANDBY"
                android:textColor="#33FF33"
                android:textSize="32sp" />
        </FrameLayout>

        <!-- Child 1: MAIN_MENU -->
        <LinearLayout
            android:id="@+id/layoutMainMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Row 1: Tera Button -->
            <Button
                android:id="@+id/btnMainTera"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/retro_button_border"
                android:text="TERA"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:paddingLeft="32dp"
                android:paddingRight="32dp"
                android:visibility="gone"
                android:backgroundTint="@null" />

            <!-- Row 2: Big Fight Button -->
            <Button
                android:id="@+id/btnMainFight"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_margin="16dp"
                android:background="@drawable/retro_button_border"
                android:text="FIGHT"
                android:textColor="#33FF33"
                android:textSize="48sp"
                android:textStyle="bold"
                android:backgroundTint="@null" />

            <!-- Row 3: Bottom action row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="8dp">

                <Button
                    android:id="@+id/btnMainBall"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="BAG"
                    android:textColor="#33FF33"
                    android:textSize="24sp"
                    android:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnMainRun"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="RUN"
                    android:textColor="#33FF33"
                    android:textSize="24sp"
                    android:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnMainPokemon"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="POKEMON"
                    android:textColor="#33FF33"
                    android:textSize="24sp"
                    android:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- Child 2: FIGHT_MENU -->
        <LinearLayout
            android:id="@+id/layoutFightMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:columnCount="2"
                android:rowCount="2">

                <Button
                    android:id="@+id/btnMove0"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="-"
                    android:textColor="#33FF33"
                    android:textSize="20sp"
                    android:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnMove1"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="-"
                    android:textColor="#33FF33"
                    android:textSize="20sp"
                    android:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnMove2"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="-"
                    android:textColor="#33FF33"
                    android:textSize="20sp"
                    android:backgroundTint="@null" />

                <Button
                    android:id="@+id/btnMove3"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_rowWeight="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:text="-"
                    android:textColor="#33FF33"
                    android:textSize="20sp"
                    android:backgroundTint="@null" />
            </GridLayout>

            <Button
                android:id="@+id/btnFightBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/retro_button_border"
                android:text="BACK"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:backgroundTint="@null" />
        </LinearLayout>

        <!-- Child 3: TARGET_SELECT -->
        <LinearLayout
            android:id="@+id/layoutTargetSelect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTargetHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Targeting:"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/targetButtonsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <Button
                android:id="@+id/btnTargetBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/retro_button_border"
                android:text="BACK"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:backgroundTint="@null" />
        </LinearLayout>

    </ViewFlipper>

</FrameLayout>