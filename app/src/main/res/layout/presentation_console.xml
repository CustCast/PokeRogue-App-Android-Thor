<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Child 0: BUSY -->
        <FrameLayout
            android:id="@+id/layoutBusy"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true">
        </FrameLayout>

        <!-- Child 1: MAIN_MENU -->
        <RelativeLayout
            android:id="@+id/layoutMainMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/cmd_bg">

            <Button
                android:id="@+id/btnMainFight"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="1240px"
                android:layout_height="783px"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="60px"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainBall"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="395px"
                android:layout_height="230px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_marginBottom="5px"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainRun"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="320px"
                android:layout_height="185px"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainPokemon"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="395px"
                android:layout_height="230px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="5px"
                android:backgroundTint="@null" />
        </RelativeLayout>

        <!-- Child 2: FIGHT_MENU -->
        <RelativeLayout
            android:id="@+id/layoutFightMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/fight_bg">

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="150px"
                android:columnCount="2"
                android:rowCount="2">

                <RelativeLayout
                    android:id="@+id/btnMove0"
                    android:layout_width="571px"
                    android:layout_height="239px"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/teraGlowMove0"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvMove0Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#33FF33"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:text="-" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvMove0Pp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#33FF33"
                                android:textSize="24sp"
                                android:text="PP: 0/0" />

                            <ImageView
                                android:id="@+id/ivMove0Eff0"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="16dp"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/ivMove0Eff1"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove1"
                    android:layout_width="571px"
                    android:layout_height="239px"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/teraGlowMove1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvMove1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#33FF33"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:text="-" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvMove1Pp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#33FF33"
                                android:textSize="24sp"
                                android:text="PP: 0/0" />

                            <ImageView
                                android:id="@+id/ivMove1Eff0"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="16dp"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/ivMove1Eff1"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove2"
                    android:layout_width="571px"
                    android:layout_height="239px"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:translationY="-20px"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/teraGlowMove2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvMove2Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#33FF33"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:text="-" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvMove2Pp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#33FF33"
                                android:textSize="24sp"
                                android:text="PP: 0/0" />

                            <ImageView
                                android:id="@+id/ivMove2Eff0"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="16dp"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/ivMove2Eff1"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove3"
                    android:layout_width="571px"
                    android:layout_height="239px"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:translationY="-20px"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:id="@+id/teraGlowMove3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvMove3Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#33FF33"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:text="-" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tvMove3Pp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="#33FF33"
                                android:textSize="24sp"
                                android:text="PP: 0/0" />

                            <ImageView
                                android:id="@+id/ivMove3Eff0"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="16dp"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/ivMove3Eff1"
                                android:layout_width="35px"
                                android:layout_height="50px"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </GridLayout>

            <FrameLayout
                android:id="@+id/btnMainTera"
                android:layout_width="175px"
                android:layout_height="204px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_marginStart="50px"
                android:layout_marginBottom="20px"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivTeraIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <View
                    android:id="@+id/teraGlowTera"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
            </FrameLayout>

            <Button
                android:id="@+id/btnFightBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="360px"
                android:layout_height="198px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="10px"
                android:layout_marginEnd="10px"
                android:backgroundTint="@null" />
        </RelativeLayout>

        <!-- Child 3: TARGET_SELECT -->
        <LinearLayout
            android:id="@+id/layoutTargetSelect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTargetHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Targeting:"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/targetButtonsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <Button
                android:id="@+id/btnTargetBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/retro_button_border"
                android:text="BACK"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:backgroundTint="@null" />
        </LinearLayout>

    </ViewFlipper>

    <!-- Global Clock & Battery -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="5dp"
        android:layout_gravity="top">

        <TextClock
            android:id="@+id/textClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:format12Hour="h:mm a"
            android:format24Hour="HH:mm" />

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:text="100%" />
    </RelativeLayout>

    <!-- Overlay for animated cursors -->
    <FrameLayout
        android:id="@+id/cursorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="10dp"
        android:focusable="false"
        android:clickable="false">

        <ImageView
            android:id="@+id/ivCursorTopLeft"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/seltopleft"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorTopRight"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/seltopright"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorBottomLeft"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/selbottomleft"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorBottomRight"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/selbottomright"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>