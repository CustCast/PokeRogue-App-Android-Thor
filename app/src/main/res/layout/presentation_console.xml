<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Child 0: BUSY -->
        <FrameLayout
            android:id="@+id/layoutBusy"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="STANDBY"
                android:textColor="#33FF33"
                android:textSize="32sp" />
        </FrameLayout>

        <!-- Child 1: MAIN_MENU -->
        <RelativeLayout
            android:id="@+id/layoutMainMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/cmd_bg">

            <Button
                android:id="@+id/btnMainFight"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="1240px"
                android:layout_height="783px"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="60px"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainBall"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="395px"
                android:layout_height="230px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_marginBottom="5px"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainRun"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="320px"
                android:layout_height="185px"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnMainPokemon"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="395px"
                android:layout_height="230px"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_marginBottom="5px"
                android:backgroundTint="@null" />
        </RelativeLayout>

        <!-- Child 2: FIGHT_MENU -->
        <RelativeLayout
            android:id="@+id/layoutFightMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/fight_bg">

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginTop="-40px"
                android:columnCount="2"
                android:rowCount="2">

                <RelativeLayout
                    android:id="@+id/btnMove0"
                    android:layout_width="571px"
                    android:layout_height="199px"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvMove0Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="55px"
                        android:textColor="#33FF33"
                        android:textSize="26sp"
                        android:text="-" />
                    <TextView
                        android:id="@+id/tvMove0Pp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="120px"
                        android:layout_marginStart="40px"
                        android:textColor="#33FF33"
                        android:textSize="24sp"
                        android:text="PP: 0/0" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove1"
                    android:layout_width="571px"
                    android:layout_height="199px"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvMove1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="55px"
                        android:textColor="#33FF33"
                        android:textSize="26sp"
                        android:text="-" />
                    <TextView
                        android:id="@+id/tvMove1Pp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="120px"
                        android:layout_marginStart="40px"
                        android:textColor="#33FF33"
                        android:textSize="24sp"
                        android:text="PP: 0/0" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove2"
                    android:layout_width="571px"
                    android:layout_height="199px"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvMove2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="55px"
                        android:textColor="#33FF33"
                        android:textSize="26sp"
                        android:text="-" />
                    <TextView
                        android:id="@+id/tvMove2Pp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="120px"
                        android:layout_marginStart="40px"
                        android:textColor="#33FF33"
                        android:textSize="24sp"
                        android:text="PP: 0/0" />
                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/btnMove3"
                    android:layout_width="571px"
                    android:layout_height="199px"
                    android:layout_margin="8dp"
                    android:background="@drawable/retro_button_border"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvMove3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="55px"
                        android:textColor="#33FF33"
                        android:textSize="26sp"
                        android:text="-" />
                    <TextView
                        android:id="@+id/tvMove3Pp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="120px"
                        android:layout_marginStart="40px"
                        android:textColor="#33FF33"
                        android:textSize="24sp"
                        android:text="PP: 0/0" />
                </RelativeLayout>
            </GridLayout>

            <Button
                android:id="@+id/btnMainTera"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:layout_margin="16dp"
                android:paddingLeft="32dp"
                android:paddingRight="32dp"
                android:background="@drawable/retro_button_border"
                android:text="TERA"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:visibility="gone"
                android:backgroundTint="@null" />

            <Button
                android:id="@+id/btnFightBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:layout_margin="16dp"
                android:paddingLeft="32dp"
                android:paddingRight="32dp"
                android:background="@drawable/retro_button_border"
                android:text="BACK"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:backgroundTint="@null" />
        </RelativeLayout>

        <!-- Child 3: TARGET_SELECT -->
        <LinearLayout
            android:id="@+id/layoutTargetSelect"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTargetHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Targeting:"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/targetButtonsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

            <Button
                android:id="@+id/btnTargetBack"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/retro_button_border"
                android:text="BACK"
                android:textColor="#33FF33"
                android:textSize="24sp"
                android:backgroundTint="@null" />
        </LinearLayout>

    </ViewFlipper>

    <!-- Global Clock & Battery -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="5dp"
        android:layout_gravity="top">

        <TextClock
            android:id="@+id/textClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:format12Hour="h:mm a"
            android:format24Hour="HH:mm" />

        <TextView
            android:id="@+id/tvBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:text="100%" />
    </RelativeLayout>

    <!-- Overlay for animated cursors -->
    <FrameLayout
        android:id="@+id/cursorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="10dp"
        android:focusable="false"
        android:clickable="false">

        <ImageView
            android:id="@+id/ivCursorTopLeft"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/seltopleft"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorTopRight"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/seltopright"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorBottomLeft"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/selbottomleft"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/ivCursorBottomRight"
            android:layout_width="80px"
            android:layout_height="80px"
            android:src="@drawable/selbottomright"
            android:visibility="gone" />
    </FrameLayout>

</FrameLayout>